# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para ".env" (na mesma pasta) e preencha os valores abaixo.
# NUNCA envie o arquivo ".env" (com os valores reais) para o GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq (obrigatório em ambos os agentes) ────────────────────────────────────
# Crie/gerencie sua chave em: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Cerebras (opcional — usado apenas como fallback no tecnico_3_2.pyw) ───────
# Crie/gerencie sua chave em: https://cloud.cerebras.ai/
# Se deixar em branco, o agente simplesmente ignora este provedor.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# ── E-mail / SMTP (usado pelo agent_gui_v4_3.pyw para enviar o ticket) ────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TECNICO=

# ── E-mail / POP3 (usado pelo tecnico_3_2.pyw para ler os tickets recebidos) ──
POP3_HOST=
POP3_PORT=110
POP3_USER=
POP3_PASSWORD=
POP3_SSL=false

# ── Modo de operação do tecnico_3_2.pyw ───────────────────────────────────────
# "principal"  = sincroniza e-mails via POP3 e salva tickets localmente
# "secundario" = apenas lê os tickets de um caminho de rede compartilhado
MODO=principal

# Caminho de rede usado somente quando MODO=secundario
# Exemplo: \\SERVIDOR\compartilhado\tickets_tecnico.json
TICKETS_REDE=
